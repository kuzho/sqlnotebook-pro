{
  "compilerOptions": {
    "jsx": "react",
    "module": "Node16",
    "target": "ES2021",
    "outDir": "dist",
    "rootDir": "src",
    "lib": ["ES2021"],
    "sourceMap": true,
    "strict": true,
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "webview"]
}