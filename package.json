{
  "name": "sqlnotebook-pro",
  "displayName": "SQL Notebook Pro",
  "publisher": "kuzho",
  "description": "View SQL files as notebooks. Execute cells and view query output. (Custom Build)",
  "icon": "media/logo128.png",
  "repository": {
    "url": "https://github.com/kuzho/sqlnotebook-pro.git"
  },
  "version": "3.0.9",
  "preview": false,
  "engines": {
    "vscode": "^1.94.0",
    "node": ">=20.0.0"
  },
  "categories": [
    "Data Science",
    "Notebooks",
    "Visualization"
  ],
  "activationEvents": [],
  "main": "./dist/index.js",
  "capabilities": {
    "virtualWorkspaces": true,
    "untrustedWorkspaces": {
      "supported": false
    }
  },
  "extensionKind": [
    "workspace"
  ],
  "contributes": {
    "notebooks": [
      {
        "type": "sql-notebook",
        "displayName": "SQL Notebook",
        "priority": "option",
        "selector": [
          {
            "filenamePattern": "*.sql"
          }
        ]
      }
    ],
    "notebookRenderer": [
      {
        "id": "sqlnotebook-pro-interactive-renderer",
        "displayName": "Interactive SQL Table",
        "entrypoint": "./dist/renderer.js",
        "mimeTypes": [
          "application/vnd.code-sql-notebook.table+json"
        ],
        "requiresMessaging": "optional"
      }
    ],
    "menus": {
      "notebook/toolbar": [
        {
          "command": "sqlnotebook.collapseAll",
          "group": "navigation",
          "when": "notebookType == 'sql-notebook' && !sqlnotebook.allCollapsed"
        },
        {
          "command": "sqlnotebook.expandAll",
          "group": "navigation",
          "when": "notebookType == 'sql-notebook' && sqlnotebook.allCollapsed"
        },
        {
          "command": "sqlnotebook.openParameters",
          "group": "navigation",
          "when": "notebookType == 'sql-notebook'"
        }
      ],
      "notebook/cell/title": [
        {
          "command": "sqlnotebook.collapseCell",
          "group": "inline@0",
          "when": "notebookType == 'sql-notebook'"
        },
        {
          "command": "sqlnotebook.expandCell",
          "group": "inline@1",
          "when": "notebookType == 'sql-notebook'"
        },
        {
          "command": "sqlnotebook.moveCellUp",
          "group": "inline@2",
          "when": "notebookType == 'sql-notebook'"
        },
        {
          "command": "sqlnotebook.moveCellDown",
          "group": "inline@3",
          "when": "notebookType == 'sql-notebook'"
        },
        {
          "command": "sqlnotebook.formatCell",
          "group": "inline@4",
          "when": "notebookType == 'sql-notebook'"
        }
      ],
      "view/item/context": [
        {
          "command": "sqlnotebook.editConnection",
          "when": "view == sqlnotebook-connections && viewItem == database",
          "group": "1_modification"
        },
        {
          "command": "sqlnotebook.deleteConnectionConfiguration",
          "when": "view == sqlnotebook-connections && viewItem == database",
          "group": "1_modification"
        },
        {
          "command": "sqlnotebook.scriptSelectTop",
          "when": "view == sqlnotebook-connections && viewItem == table",
          "group": "1_modification"
        }
      ],
      "view/title": [
        {
          "command": "sqlnotebook.refreshConnectionPanel",
          "when": "view == sqlnotebook-connections",
          "group": "navigation"
        }
      ]
    },
    "commands": [
      {
        "command": "sqlnotebook.editConnection",
        "title": "Edit Connection",
        "icon": "$(edit)"
      },
      {
        "command": "sqlnotebook.deleteConnectionConfiguration",
        "title": "Delete SQL Connection Configuration"
        },
        {
          "command": "sqlnotebook.scriptSelectTop",
          "title": "Select Top 100 Rows"
      },
      {
        "command": "sqlnotebook.refreshConnectionPanel",
        "title": "Refresh SQL Connection Panel",
        "icon": "$(refresh)",
        "shortTitle": "Refresh"
      },
      {
        "command": "sqlnotebook.collapseAll",
        "title": "Collapse All Codes",
        "icon": "$(collapse-all)"
      },
      {
        "command": "sqlnotebook.expandAll",
        "title": "Expand All Codes",
        "icon": "$(expand-all)"
      },
      {
        "command": "sqlnotebook.openParameters",
        "title": "SQL Parameters",
        "icon": "$(symbol-variable)"
      },
      {
        "command": "sqlnotebook.refreshKernels",
        "title": "Refresh Kernels"
      },
      {
        "command": "sqlnotebook.collapseCell",
        "title": "Collapse Cell",
        "icon": "$(chevron-up)"
      },
      {
        "command": "sqlnotebook.expandCell",
        "title": "Expand Cell",
        "icon": "$(chevron-down)"
      },
      {
        "command": "sqlnotebook.moveCellUp",
        "title": "Move Cell Up",
        "icon": "$(arrow-up)"
      },
      {
        "command": "sqlnotebook.moveCellDown",
        "title": "Move Cell Down",
        "icon": "$(arrow-down)"
      },
      {
        "command": "sqlnotebook.formatCell",
        "title": "Format SQL",
        "icon": "$(symbol-string)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sqlnotebook",
          "title": "SQL Notebook",
          "icon": "media/logo.svg"
        }
      ]
    },
    "configuration": {
      "title": "SQL Notebook",
      "properties": {
        "sqlnotebook.connections": {
          "type": "array",
          "default": [],
          "description": "List of saved database connection configurations.",
          "scope": "window"
        },
        "sqlnotebook.queryTimeout": {
          "type": "number",
          "default": 30000,
          "description": "Query timeout in milliseconds for cell query execution."
        },
        "sqlnotebook.maxResultRows": {
          "type": "number",
          "default": 100,
          "description": "Maximum number of result rows to display before truncating result table."
        },
        "sqlnotebook.openAfterExport": {
          "type": "boolean",
          "default": true,
          "description": "Automatically open Excel/CSV files after exporting."
        },
        "sqlnotebook.safeDelete": {
          "type": "boolean",
          "default": true,
          "description": "Prevent execution of DELETE and UPDATE statements without a WHERE clause."
        }
      }
    },
    "views": {
      "sqlnotebook": [
        {
          "id": "sqlnotebook-connections",
          "name": "SQL Connections",
          "visibility": "visible",
          "icon": "media/logo.svg",
          "contextualTitle": "Connections"
        },
        {
          "type": "webview",
          "id": "sqlnotebook.connectionForm",
          "name": "New SQL Connection",
          "contextualTitle": "New Connection",
          "visibility": "visible",
          "icon": "media/logo.svg"
        },
        {
          "type": "webview",
          "id": "sqlnotebook.parameters",
          "name": "Parameters",
          "visibility": "visible",
          "icon": "media/logo.svg"
        },
        {
          "id": "sqlnotebook-helpfeedback",
          "name": "Help and Feedback",
          "visibility": "collapsed",
          "icon": "media/logo.svg",
          "contextualTitle": "Help and Feedback"
        }
      ]
    },
    "keybindings": [
      {
        "command": "sqlnotebook.openParameters",
        "key": "f5",
        "when": "editorTextFocus && editorLangId == 'sql'"
      }
    ]
  },
  "scripts": {
    "build": "npm run compile && npx @vscode/vsce package",
    "vscode:prepublish": "npm run compile",
    "compile": "npm run build:server && npm run build:webview && npm run build:parameters && npm run build:renderer && shx mkdir -p dist/node_modules && shx cp -r node_modules/sql.js dist/node_modules",
    "build:server": "esbuild ./src/main.ts --sourcemap --minify --bundle --platform=node --external:vscode --external:pg-native --outfile=./dist/index.js",
    "build:webview": "esbuild ./webview/main.tsx --sourcemap --minify --bundle --outfile=./dist/webview/main-bundle.js",
    "build:parameters": "esbuild ./webview/parameters-main.tsx --sourcemap --minify --bundle --outfile=./dist/webview/parameters-bundle.js",
    "build:renderer": "esbuild ./src/renderer.tsx --bundle --outfile=./dist/renderer.js --format=esm --platform=browser",
    "clean": "rm -rf ./dist",
    "lint": "eslint src --ext ts",
    "watch": "npm run build:server -- --watch & npm run build:webview -- --watch & npm run build:parameters -- --watch & npm run build:renderer -- --watch",
    "fmt": "prettier --write --ignore-path .gitignore ."
  },
  "devDependencies": {
    "@types/escape-html": "^1.0.4",
    "@types/mocha": "^10.0.7",
    "@types/node": "^18.0.0",
    "@types/pg": "^8.6.1",
    "@types/mssql": "^9.1.5",
    "@types/react": "^17.0.37",
    "@types/react-dom": "^17.0.11",
    "@types/sql.js": "^1.4.3",
    "@types/vscode": "^1.94.0",
    "@types/vscode-notebook-renderer": "^1.57.8",
    "@types/vscode-webview": "^1.57.0",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "@vscode/codicons": "^0.0.35",
    "@vscode/vsce": "^3.9.0",
    "esbuild": "^0.27.2",
    "eslint": "^8.57.0",
    "glob": "^10.4.2",
    "ovsx": "^0.8.3",
    "prettier": "^3.3.2",
    "shx": "^0.3.4",
    "typescript": "^5.0.4",
    "vscode-languageclient": "^9.0.1",
    "vscode-notebook-error-overlay": "^1.0.1",
    "vscode-test": "^1.4.1"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "@vscode/webview-ui-toolkit": "^1.4.0",
    "flatpickr": "^4.6.13",
    "icons-react": "^3.7.1",
    "mssql": "^12.2.0",
    "mysql2": "^3.16.0",
    "pg": "^8.12.0",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "sql-formatter": "^15.4.0",
    "sql.js": "^1.10.3",
    "trino-client": "^0.2.9",
    "xlsx": "https://cdn.sheetjs.com/xlsx-latest/xlsx-latest.tgz"
  },
  "overrides": {
    "axios": "^1.7.9"
  },
  "prettier": {
    "semi": true,
    "singleQuote": true
  }
}
